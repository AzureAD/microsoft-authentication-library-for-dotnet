<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>netstandard2.0;net48;net8.0</TargetFrameworks>
    <IsPackable>true</IsPackable>
    <AssemblyName>Microsoft.Identity.Client.TestOnly</AssemblyName>
    <Configurations>Debug;Release</Configurations>
    <!-- Strong naming is inherited from Directory.Build.props -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>CS1591;CS1574;IL2070;IL2072;IL2087</NoWarn>
    <!-- Disable nullable to prevent IsAotCompatible (net8.0) from implying Nullable=enable,
         which would cause PublicApiAnalyzer entries to require '!' annotations on Windows CI. -->
    <Nullable>disable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="MSTest.TestFramework" />
    <PackageReference Include="Newtonsoft.Json" />
    <PackageReference Include="NSubstitute" />
    <PackageReference Include="NSubstitute.Analyzers.CSharp">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="System.Net.Http" />
    <PackageReference Include="System.Reflection.TypeExtensions" />
    <PackageReference Include="System.Threading" />
    <PackageReference Include="System.Threading.Tasks" />
    <PackageReference Include="System.Threading.Tasks.Parallel" />
    <PackageReference Include="System.Threading.Thread" />
    <PackageReference Include="System.ValueTuple" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Microsoft.Identity.Client\Microsoft.Identity.Client.csproj" />
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="PublicApi/$(TargetFramework)/PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicApi/$(TargetFramework)/PublicAPI.Unshipped.txt" />
  </ItemGroup>
</Project>
