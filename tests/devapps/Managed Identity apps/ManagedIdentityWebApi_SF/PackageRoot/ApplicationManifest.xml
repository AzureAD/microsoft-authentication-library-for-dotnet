<?xml version="1.0" encoding="utf-8"?>
<ApplicationManifest xmlns:xsd="http://www.w3.org/2001/XMLSchema"
                     xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                     ApplicationTypeName="ManagedIdentityWebApi_SFType"
                     ApplicationTypeVersion="1.0.0"
                     xmlns="http://schemas.microsoft.com/2011/01/fabric">
  <Parameters>
    <Parameter Name="ManagedIdentityWebApi_SF_InstanceCount" DefaultValue="-1" />
  </Parameters>
  <!-- Import the ServiceManifest from the ServicePackage. The ServiceManifestName and ServiceManifestVersion
       should match the Name and Version attributes of the ServiceManifest element defined in the
       ServiceManifest.xml file. -->
  <ServiceManifestImport>
    <ServiceManifestRef ServiceManifestName="ManagedIdentityWebApi_SFPkg" ServiceManifestVersion="1.0.0" />
    <ConfigOverrides />
    <Policies>
      <!-- Bind the service-level identity name (ServiceManifest) to the application-level principal (Principals below).
           When the ARM application resource carries a system-assigned identity, reference "systemAssignedIdentity".
           When the ARM application resource carries a user-assigned identity, reference "userAssignedIdentity". -->
      <IdentityBindingPolicy ServiceIdentityRef="systemAssignedRef" ApplicationIdentityRef="systemAssignedIdentity" />
      <IdentityBindingPolicy ServiceIdentityRef="userAssignedRef"   ApplicationIdentityRef="userAssignedIdentity" />
    </Policies>
  </ServiceManifestImport>

  <!-- Declare the managed identities this application may carry.
       The Name values here must match the ApplicationIdentityRef values in IdentityBindingPolicy above,
       and must also match the "managedIdentities[].name" values in the ARM application resource properties
       (arm/application.json) so the SF runtime can resolve the correct token endpoint. -->
  <Principals>
    <ManagedIdentities>
      <!-- Maps to the application's system-assigned Azure managed identity -->
      <ManagedIdentity Name="systemAssignedIdentity" />
      <!-- Maps to a user-assigned Azure managed identity bound via the ARM template -->
      <ManagedIdentity Name="userAssignedIdentity" />
    </ManagedIdentities>
  </Principals>

  <DefaultServices>
    <!-- The section below creates instances of service types, when an instance of this
         application type is created. You can also create one or more instances of service type using the
         ServiceFabric PowerShell module.

         The attribute ServiceTypeName below must match the name defined in the imported ServiceManifest.xml file. -->
    <Service Name="ManagedIdentityWebApi_SF" ServicePackageActivationMode="ExclusiveProcess">
      <StatelessService ServiceTypeName="ManagedIdentityWebApi_SFType" InstanceCount="[ManagedIdentityWebApi_SF_InstanceCount]">
        <SingletonPartition />
      </StatelessService>
    </Service>
  </DefaultServices>
</ApplicationManifest>
