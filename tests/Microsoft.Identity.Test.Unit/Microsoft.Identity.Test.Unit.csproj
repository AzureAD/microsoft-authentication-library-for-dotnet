<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworkNetDesktop48>net48</TargetFrameworkNetDesktop48>
    <TargetFrameworkNet>net8.0</TargetFrameworkNet>
    <TargetFrameworkNetDesktop462>net462</TargetFrameworkNetDesktop462>
    <TargetFrameworkNetDesktop472>net472</TargetFrameworkNetDesktop472>

    <TargetFrameworks>$(TargetFrameworkNetDesktop48);$(TargetFrameworkNet);$(TargetFrameworkNetDesktop462);$(TargetFrameworkNetDesktop472)</TargetFrameworks>
    <IsPackable>false</IsPackable>

    <Configurations>Debug;Release;Debug + MobileApps</Configurations>

    <Platforms>AnyCPU;x64</Platforms>
</PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\client\Microsoft.Identity.Client.Desktop\Microsoft.Identity.Client.Desktop.csproj" Condition="$(TargetFramework)==$(TargetFrameworkNetDesktop48) Or $(TargetFramework)==$(TargetFrameworkNetDesktop462)" />
    <ProjectReference Include="..\..\src\client\Microsoft.Identity.Client.Broker\Microsoft.Identity.Client.Broker.csproj" />
    <ProjectReference Include="..\..\src\client\Microsoft.Identity.Client.Extensions.Msal\Microsoft.Identity.Client.Extensions.Msal.csproj" />
    <ProjectReference Include="..\..\src\client\Microsoft.Identity.Client.KeyAttestation\Microsoft.Identity.Client.KeyAttestation.csproj" />
    <ProjectReference Include="..\..\src\client\Microsoft.Identity.Client\Microsoft.Identity.Client.csproj">
      <Project>{3433eb33-114a-4db7-bc57-14f17f55da3c}</Project>
      <Name>Microsoft.Identity.Client</Name>
    </ProjectReference>
    <ProjectReference Include="..\..\src\client\Microsoft.Identity.Lab.Api\Microsoft.Identity.Lab.Api.csproj" />
    <ProjectReference Include="..\Microsoft.Identity.Test.Common\Microsoft.Identity.Test.Common.csproj" />
    <PackageReference Include="Microsoft.AspNet.WebApi.Client" />
    <PackageReference Include="Microsoft.IdentityModel.Abstractions" />
    <PackageReference Include="NSubstitute" />
    <PackageReference Include="NSubstitute.Analyzers.CSharp">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="NuGet.Versioning" />
    <PackageReference Include="OpenTelemetry.Exporter.Console" />
    <PackageReference Include="OpenTelemetry.Exporter.InMemory" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="MSTest.TestAdapter" />
    <PackageReference Include="MSTest.TestFramework" />
    <PackageReference Include="Polly" />
    <PackageReference Include="System.IdentityModel.Tokens.Jwt" />
    <!-- This reference is a workaround for a bug in .net46
    https://stackoverflow.com/questions/45563560/could-not-load-file-or-assembly-system-net-http-version-4-1-1-1-net-standard-->
    <PackageReference Include="System.Net.Http" />
    <PackageReference Include="System.IO.FileSystem.AccessControl" />
    <PackageReference Include="Selenium.WebDriver" />
    <PackageReference Include="System.Formats.Asn1" />

    <PackageReference Include="coverlet.collector">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>

    <PackageReference Include="System.Security.Cryptography.ProtectedData" />

    <Compile Remove="Resources\**" />
    <EmbeddedResource Remove="Resources\**" />
    <None Include="Resources\**" />
    <None Update="Resources\**\*">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>

  </ItemGroup>

  <!-- net472 doesn't have Microsoft.Identity.Client.Desktop (targets net462 only), exclude WebView2 test that needs it -->
  <!-- Also exclude ClientCredentialWithCertTest which uses GetCertHash(HashAlgorithmName) added in net48 -->
  <ItemGroup Condition="'$(TargetFramework)' == '$(TargetFrameworkNetDesktop472)'">
    <Compile Remove="WebUITests\WebView2WebUiFactoryTests.cs" />
    <Compile Remove="PublicApiTests\ClientCredentialWithCertTest.cs" />
  </ItemGroup>

  <!-- net462 lacks CertificateRequest / ECCurve (added in 4.7.1/4.7.2); exclude those test files -->
  <!-- Also excludes ManagedIdentityTests\ entirely because ImdsV2 is unsupported on net462 -->
  <ItemGroup Condition="'$(TargetFramework)' == '$(TargetFrameworkNetDesktop462)'">
    <Compile Remove="Helpers\CertHelper.cs" />
    <Compile Remove="CryptographyTests.cs" />
    <Compile Remove="CoreTests\HttpTests\HttpClientFactoryTests.cs" />
    <Compile Remove="CoreTests\HttpTests\HttpManagerTests.cs" />
    <Compile Remove="ExceptionTests\ExperimentalFeatureTests.cs" />
    <Compile Remove="ManagedIdentityTests\**" />
    <Compile Remove="PublicApiTests\ClientAssertionTests.cs" />
    <Compile Remove="PublicApiTests\ClientCredentialWithCertTest.cs" />
    <Compile Remove="PublicApiTests\ConfidentialClientApplicationExtensibilityTests.cs" />
    <Compile Remove="PublicApiTests\ConfidentialClientApplicationTests.cs" />
    <Compile Remove="PublicApiTests\MtlsPopTests.cs" />
    <Compile Remove="RequestsTests\CredentialMatrixTests.cs" />
    <Compile Remove="WebUITests\WebView2WebUiFactoryTests.cs" />
  </ItemGroup>

  <Import Project="../../build/platform_and_feature_flags.props" />

  <ItemGroup Condition="'$(TargetFramework)' == '$(TargetFrameworkNetDesktop48)' Or '$(TargetFramework)' == '$(TargetFrameworkNetDesktop462)' Or '$(TargetFramework)' == '$(TargetFrameworkNetDesktop472)'">
    <PackageReference Include="System.Windows.Forms" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="CacheExtension\" />
  </ItemGroup>
  <PropertyGroup Condition="'$(TargetFramework)' == '$(TargetFrameworkNet)'">
    <DefineConstants>$(DefineConstants);NET_CORE</DefineConstants>
  </PropertyGroup>

</Project>
